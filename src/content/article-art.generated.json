  "styleDirection": {
    "intent": "Make the site feel closer to a literary Christian magazine than a generic landing-page stack.",
    "visualGoals": [
      "editorial, literary, intelligent, calm",
      "hopeful and warm rather than dark or cynical",
      "hand-painted and illustrated rather than photoreal",
      "clear focal subjects with generous negative space",
      "subtle Christian cues without stock-photo church clichés"
    ],
    "visualLanguage": [
      "ink-and-gouache editorial illustration",
      "soft watercolor edges",
      "restrained magazine-cover composition",
      "elegant silhouettes and symbolic scenes",
      "paper texture, quiet atmosphere, story-first composition"
    ],
    "avoid": [
      "photorealism",
      "stock-photo poses",
      "3D marketing renders",
      "text embedded in the image",
      "generic handshake hero art",
      "dark apocalyptic religious imagery",
      "busy neon palettes",
      "interface mockups inside the illustration"
    ]
  },
